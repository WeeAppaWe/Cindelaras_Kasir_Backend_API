# Copy these Docker-specific values into .env for deployment, or use them
# as a checklist when preparing your production env file.

APP_IMAGE=sistem-kasir-backend-api:latest
APP_ENV_FILE=.env
APP_PORT=4000
CONTAINER_PORT=3000

POSTGRES_USER=sistem_kasir
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=sistem_kasir

# Optional override. If omitted, compose builds DATABASE_URL from POSTGRES_* above.
# DOCKER_DATABASE_URL=postgresql://sistem_kasir:change_this_postgres_password@postgres:5432/sistem_kasir?schema=public
DATABASE_SSL_CA_PATH=certs/prod-ca-2021.crt

DOCKER_REDIS_HOST=redis
DOCKER_REDIS_PORT=6379
REDIS_PASS=change_this_redis_password

AUTH_TOKEN_EXPIRED_TIME_MINUTE=2880
FORGOT_PASSWORD_OTP_TTL_SECONDS=300
FORGOT_PASSWORD_OTP_MAX_ATTEMPTS=5
FORGOT_PASSWORD_OTP_LOCK_ATTEMPTS=3
FORGOT_PASSWORD_OTP_LOCK_SECONDS=60
FORGOT_PASSWORD_RESET_TOKEN_TTL_SECONDS=600

# Supabase Storage
# Use service role key only on backend/server environment.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change_this_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=images
SUPABASE_STORAGE_PUBLIC_URL=https://your-project-ref.supabase.co/storage/v1/object/public/images
SUPABASE_FOLDER_MENU=menus
SUPABASE_FOLDER_LOGO=logos
